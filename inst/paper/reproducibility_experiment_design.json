  "metrics": {
    "primary_metrics": {
      "state_reproducibility_rate": {
        "definition": "Proportion of labeled snapshots that can be exactly restored",
        "formula": "successful_restorations / total_restoration_attempts",
        "measurement_method": "all.equal() with tolerance=1e-8 for numerical, identical() for categorical",
        "target": ">=0.99 (99%)",
        "unit": "proportion"
      },
      "dependency_completeness": {
        "definition": "Proportion of true dependencies correctly captured in lineage graph",
        "formula": "(true_positives) / (true_positives + false_negatives)",
        "measurement_method": "Compare declared depends_on edges with __ol_dependencies records",
        "target": "1.0 (100%)",
        "unit": "proportion"
      },
      "dependency_precision": {
        "definition": "Proportion of recorded dependencies that are valid",
        "formula": "(true_positives) / (true_positives + false_positives)",
        "measurement_method": "Audit __ol_dependencies for phantom edges",
        "target": "1.0 (100%)",
        "unit": "proportion"
      },
      "rollback_success_rate": {
        "definition": "Proportion of rollback operations that restore consistent state",
        "formula": "successful_rollbacks / total_rollback_attempts",
        "measurement_method": "Verify all objects at label reference match expected values",
        "target": "1.0 (100%)",
        "unit": "proportion"
      }
    },
    "secondary_metrics": {
      "restoration_latency_p50": {
        "definition": "Median time to restore a snapshot",
        "measurement_method": "microbenchmark::microbenchmark(ol_read(..., ref=...))",
        "target": "<1.0 second",
        "unit": "seconds"
      },
      "restoration_latency_p95": {
        "definition": "95th percentile time to restore a snapshot",
        "target": "<5.0 seconds",
        "unit": "seconds"
      },
      "lineage_query_latency": {
        "definition": "Time to traverse full dependency graph",
        "measurement_method": "Time ol_show_lineage() for max_depth=10",
        "target": "<2.0 seconds",
        "unit": "seconds"
      },
      "storage_overhead_ratio": {
        "definition": "Additional storage required for versioning relative to raw data",
        "formula": "(versioned_db_size - raw_data_size) / raw_data_size",
        "target": "<0.5 (50% overhead acceptable)",
        "unit": "ratio"
      },
      "cross_environment_consistency": {
        "definition": "Proportion of environment pairs with identical results",
        "formula": "consistent_pairs / total_pairs",
        "target": "1.0 (100%)",
        "unit": "proportion"
      }
    },
    "derived_metrics": {
      "reproducibility_f1_score": {
        "definition": "Harmonic mean of restoration precision and recall",
        "formula": "2 * (precision * recall) / (precision + recall)",
        "target": ">=0.99"
      },
      "scalability_index": {
        "definition": "Performance ratio at 10000 versions vs 100 versions",
        "formula": "latency_at_10k / latency_at_100",
        "target": "<3.0 (sublinear degradation)"
      }
    }
  },

  "experimental_protocol": {
    "sample_sizes": {
      "state_restoration_tests": {
        "iterations_per_scenario": 10,
        "total_scenarios": 4,
        "statistical_power": 0.80,
        "alpha": 0.05
      },
      "lineage_tests": {
        "graph_configurations": 5,
        "traversals_per_config": 20
      },
      "cross_environment_tests": {
        "environment_pairs": 6,
        "iterations_per_pair": 3
      },
      "scalability_tests": {
        "version_count_levels": 4,
        "measurements_per_level": 100
      }
    },
    "randomization": {
      "seed": 42,
      "data_generation": "Controlled random data to ensure reproducibility of test itself",
      "operation_order": "Fixed sequence for comparability"
    },
    "controls": {
      "positive_control": "Known good OmicsLake project with verified snapshots",
      "negative_control": "Intentionally corrupted snapshot to verify detection"
    }
  },

  "reporting": {
    "output_artifacts": [
      {
        "name": "results_reproducibility_summary.csv",
